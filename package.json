{
  "name": "react-bottom-lock",
  "version": "1.0.1",
  "description": "Sticky bottom scrolling for React chat and streaming UIs.",
  "keywords": [
    "chat",
    "react",
    "react-virtuoso",
    "react-window",
    "scroll",
    "stick-to-bottom",
    "tanstack-virtual",
    "virtual-list"
  ],
  "homepage": "https://github.com/Matrix-The-One/react-bottom-lock#readme",
  "bugs": {
    "url": "https://github.com/Matrix-The-One/react-bottom-lock/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Matrix-The-One/react-bottom-lock.git"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "LICENSE",
    "NOTICE.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "changeset": "changeset",
    "dev": "vp pack --watch",
    "build": "vp pack",
    "build:lib": "vp pack",
    "build:watch": "vp pack --watch",
    "lint": "vp lint",
    "check": "vp check",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "esbuild": "^0.28.0",
    "react": "^19.2.5",
    "typescript": "~6.0.2",
    "vite-plus": "^0.1.16"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
